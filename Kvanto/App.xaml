<Application
    x:Class="Kvanto.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kvanto">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App color palette -->
            <Color x:Key="KvantoPrimaryColor">#6366F1</Color>
            <Color x:Key="KvantoSecondaryColor">#8B5CF6</Color>
            <Color x:Key="KvantoAccentColor">#F59E0B</Color>
            <Color x:Key="KvantoSuccessColor">#10B981</Color>
            <Color x:Key="KvantoDangerColor">#EF4444</Color>
            <Color x:Key="KvantoSurfaceColor">#1E1E2E</Color>
            <Color x:Key="KvantoSurface2Color">#313244</Color>

            <SolidColorBrush x:Key="KvantoPrimaryBrush" Color="{StaticResource KvantoPrimaryColor}" />
            <SolidColorBrush x:Key="KvantoSecondaryBrush" Color="{StaticResource KvantoSecondaryColor}" />
            <SolidColorBrush x:Key="KvantoAccentBrush" Color="{StaticResource KvantoAccentColor}" />
            <SolidColorBrush x:Key="KvantoSuccessBrush" Color="{StaticResource KvantoSuccessColor}" />
            <SolidColorBrush x:Key="KvantoDangerBrush" Color="{StaticResource KvantoDangerColor}" />

            <!-- Pomodoro state colors -->
            <Color x:Key="PomodoroWorkColor">#EF4444</Color>
            <Color x:Key="PomodoroBreakColor">#10B981</Color>
            <SolidColorBrush x:Key="PomodoroWorkBrush" Color="{StaticResource PomodoroWorkColor}" />
            <SolidColorBrush x:Key="PomodoroBreakBrush" Color="{StaticResource PomodoroBreakColor}" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
