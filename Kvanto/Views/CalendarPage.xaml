<Page
    x:Class="Kvanto.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kvanto.Views"
    xmlns:vm="using:Kvanto.ViewModels"
    xmlns:conv="using:Kvanto.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:CalendarDayBackgroundConverter x:Key="DayBackground" />
    </Page.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Calendar" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="See which tasks you worked on each day"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- ── Month Navigation ── -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Command="{x:Bind ViewModel.NavigatePreviousMonthCommand}">
                <FontIcon Glyph="&#xE76B;" FontSize="14" />
            </Button>
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.MonthLabel, Mode=OneWay}"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Button Grid.Column="2" Command="{x:Bind ViewModel.NavigateNextMonthCommand}">
                <FontIcon Glyph="&#xE76C;" FontSize="14" />
            </Button>
        </Grid>

        <!-- ── Day-of-week headers ── -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Mon" HorizontalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="1" Text="Tue" HorizontalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="2" Text="Wed" HorizontalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="3" Text="Thu" HorizontalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="4" Text="Fri" HorizontalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="5" Text="Sat" HorizontalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Grid.Column="6" Text="Sun" HorizontalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </Grid>

        <!-- ── Calendar Grid (6 weeks × 7 days) ── -->
        <ItemsControl Grid.Row="3"
                      ItemsSource="{x:Bind ViewModel.CalendarDays, Mode=OneWay}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CalendarDayViewModel">
                    <Border Margin="2" CornerRadius="8" Padding="6"
                            Background="{Binding Converter={StaticResource DayBackground}}"
                            MinHeight="80"
                            Tapped="OnCalendarDayTapped"
                            Tag="{x:Bind}">
                        <StackPanel Spacing="2">
                            <!-- Day number -->
                            <TextBlock Text="{x:Bind Date.Day}"
                                       FontSize="13" />

                            <!-- Task entries (colored blocks) -->
                            <ItemsControl ItemsSource="{x:Bind TaskEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CalendarTaskEntry">
                                        <Border CornerRadius="3" Padding="3,1" Margin="0,1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{x:Bind Color}" Opacity="0.8" />
                                            </Border.Background>
                                            <TextBlock Text="{x:Bind DisplayText}"
                                                       FontSize="10" Foreground="White"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Total minutes badge -->
                            <TextBlock
                                Text="{x:Bind TotalMinutes}"
                                FontSize="10"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Visibility="{x:Bind TotalMinutes, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
