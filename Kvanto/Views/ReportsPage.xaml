<Page
    x:Class="Kvanto.Views.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kvanto.Views"
    xmlns:vm="using:Kvanto.ViewModels"
    xmlns:conv="using:Kvanto.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:FractionToWidthConverter x:Key="FractionToWidth" />
    </Page.Resources>

    <ScrollViewer>
        <Grid Margin="24,16" MaxWidth="900">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Reports &amp; Analytics" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="Understand how you spend your time"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- ── Date range picker + quick selects ── -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,20">
                <DatePicker Header="From" Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}" />
                <DatePicker Header="To"   Date="{x:Bind ViewModel.ToDate,   Mode=TwoWay}" />
                <Button Content="Last 7 days"  Command="{x:Bind ViewModel.SetRangeLastWeekCommand}"
                        VerticalAlignment="Bottom" />
                <Button Content="Last 30 days" Command="{x:Bind ViewModel.SetRangeLastMonthCommand}"
                        VerticalAlignment="Bottom" />
                <Button Content="This year"    Command="{x:Bind ViewModel.SetRangeThisYearCommand}"
                        VerticalAlignment="Bottom" />
                <Button Content="Refresh"
                        Command="{x:Bind ViewModel.LoadReportCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        VerticalAlignment="Bottom" />
            </StackPanel>

            <!-- ── Summary cards ── -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <local:SummaryCard Grid.Column="0" Icon="&#xE916;" Label="Total Time"
                                   Value="{x:Bind ViewModel.TotalWorkedDisplay, Mode=OneWay}" />
                <local:SummaryCard Grid.Column="1" Icon="&#xE768;" Label="Sessions"
                                   Value="{x:Bind ViewModel.TotalSessions, Mode=OneWay}" />
                <local:SummaryCard Grid.Column="2" Icon="&#xE787;" Label="Active Days"
                                   Value="{x:Bind ViewModel.TotalDays, Mode=OneWay}" />
                <local:SummaryCard Grid.Column="3" Icon="&#xE9D9;" Label="Daily Avg"
                                   Value="{x:Bind ViewModel.AverageDailyDisplay, Mode=OneWay}" />
                <local:SummaryCard Grid.Column="4" Icon="&#xE783;" Label="Streak"
                                   Value="{x:Bind ViewModel.CurrentStreak, Mode=OneWay}" />
            </Grid>

            <!-- ── Daily activity bar chart ── -->
            <StackPanel Grid.Row="3" Margin="0,0,0,20">
                <TextBlock Text="Daily Activity" Style="{ThemeResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,12" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DailyTotals, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:DailyTotalItem">
                                    <StackPanel Width="32" VerticalAlignment="Bottom" Spacing="2">
                                        <TextBlock Text="{x:Bind MinutesLabel}"
                                                   FontSize="9" HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <Border CornerRadius="3"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                Height="{x:Bind Minutes}"
                                                MaxHeight="160" MinHeight="4"
                                                ToolTipService.ToolTip="{x:Bind MinutesLabel}" />
                                        <TextBlock Text="{x:Bind DateLabel}"
                                                   FontSize="9" HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- ── Per-task breakdown ── -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="Time by Task" Style="{ThemeResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,12" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.TaskAnalytics, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskAnalyticsItem">
                                <Grid Margin="0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Title + stats row -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="{x:Bind Category}" />
                                                <Run Text=" · " />
                                                <Run Text="{x:Bind Sessions}" />
                                                <Run Text=" sessions · " />
                                                <Run Text="{x:Bind WorkedDays}" />
                                                <Run Text=" days" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind TotalTimeDisplay}"
                                                   FontWeight="Bold" FontSize="16"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Progress bar -->
                                    <Grid Grid.Row="1" Height="8" Margin="0,6,0,0"
                                          Background="{ThemeResource ControlFillColorDefaultBrush}"
                                          CornerRadius="4">
                                        <Border CornerRadius="4"
                                                HorizontalAlignment="Left"
                                                Height="8"
                                                Width="{x:Bind BarWidthFraction, Converter={StaticResource FractionToWidth}}">
                                            <Border.Background>
                                                <SolidColorBrush Color="{x:Bind Color}" />
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <Rectangle Grid.Row="2" Height="1" Margin="0,10,0,0"
                                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
